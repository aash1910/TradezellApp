{
  "expo": {
    "name": "PiqDrop",
    "slug": "piqdrop",
    "version": "1.0.5",
    "orientation": "portrait",
    "icon": "./assets/icons/ios-dark.png",
    "scheme": "piqdrop",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "facebookAppId": "1018394353841992",
    "facebookDisplayName": "PiqDrop",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.piqdrop.com",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "This app needs access to your location to show your current location on the map.",
        "NSLocationAlwaysUsageDescription": "This app needs access to your location to show your current location on the map.",
        "NSCameraUsageDescription": "This app needs access to your camera to take photos of your vehicle.",
        "NSPhotoLibraryUsageDescription": "This app needs access to your photo library to save photos of your vehicle.",
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["fb1018394353841992"]
          }
        ],
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "FirebaseAppDelegateProxyEnabled": false
      },
      "icon": {
        "dark": "./assets/icons/ios-dark.png",
        "light": "./assets/icons/ios-dark.png",
        "tinted": "./assets/icons/ios-tinted.png"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/adaptive-icon.png",
        "backgroundColor": "#55B086"
      },
      "package": "com.piqdrop.app",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "ios": {
            "backgroundColor": "#55B086",
            "image": "./assets/images/splash-screen-1.png",
            "resizeMode": "contain",
            "enableFullScreenImage_legacy": true
          },
          "android": {
            "backgroundColor": "#55B086",
            "image": "./assets/icons/splash-icon-dark.png",
            "imageWidth": 200
          }
        }
      ],
      "expo-localization",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.885136208940-c07brsdi2plaqiijmfq9rslnmnlvi7bt"
        }
      ],
      "expo-facebook"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "f4e2a653-4467-4908-8aba-ce3b2ef4015d"
      },
      "stripePublishableKey": "pk_test_51RaMqGBQsHpfCUCmVUDUmoJ3Mi7u6rJlb9mFJVhpMqKacI3JNcGIosKGaQLLvCXnIBGL30TilKbLpKp0rxCrsffP0073sjbHOE",
      "currency": {
        "code": "SEK",
        "symbol": "kr",
        "locale": "sv-SE",
        "maxWithdrawal": 100000,
        "minWithdrawal": 100
      }
    }
  }
}
